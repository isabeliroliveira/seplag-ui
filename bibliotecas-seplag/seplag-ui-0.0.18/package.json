{
  "name": "@seplag/ui-lib-react-18",
  "private": false,
  "version": "0.0.18",
  "type": "module",
  "description": "Design System padrão Seplag — biblioteca de componentes React",
  "author": "Seplag",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "bin": {
    "seplag-generate": "dist/_generator/generate.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean:dist": "rimraf dist",
    "start": "vite",
    "dev": "vite",
    "copy:generator": "node -e \"const {cpSync} = require('fs'); cpSync('src/_generator', 'dist/_generator', {recursive: true}); cpSync('src/template', 'dist/template', {recursive: true});\"",
    "build": "npm run clean:dist && vite build && npm run copy:generator",
    "pack": "npm pack",
    "pack:local": "npm run build && npm pack",
    "package": "npm run build && npm publish",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": ">=2",
    "primeflex": ">=3",
    "primeicons": ">=7",
    "primereact": ">=10",
    "react": ">=18",
    "react-cropper": ">=2",
    "react-dom": ">=18",
    "react-google-recaptcha": ">=3",
    "react-hook-form": ">=7",
    "react-icons": ">=5",
    "react-redux": ">=9",
    "react-router-dom": ">=7",
    "react-transition-group": ">=4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "npmconfigset": {
    "@seplag:registry": "http://git.seplag.mt.gov.br/api/v4/projects/CI_PROJECT_ID/packages/npm/"
  }
}
